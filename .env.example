# Sample .env for VPS deployment
#
# Use nip.io to expose the stack on a public IP without owning a DNS zone.
# Replace 203.0.113.10 with the actual public IP of the VPS.
# `nip.io` resolves any subdomain like `dashboard.203-0-113-10.nip.io`
# back to the IP encoded in the hostname.

DASHBOARD_DOMAIN=dashboard.203-0-113-10.nip.io
MOBILE_DOMAIN=mobile.203-0-113-10.nip.io
API_DOMAIN=api.203-0-113-10.nip.io

# Required by docker-compose.yml services
JWT_SECRET_KEY=replace-with-a-long-random-secret-string-32+chars

# OCR external integration (defaults baked into config.py if omitted)
OCR_API_BASE_URL=http://136.116.56.229:8000/apis/ocr
OCR_API_TIMEOUT_SECONDS=30
